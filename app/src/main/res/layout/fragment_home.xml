<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_introduce_gradient"
    tools:context=".projectPractice.HomeFragment">


    <!-- 整体可滚动容器（页面内容多需要滑动） -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="20dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="每日书摘"
                android:textColor="#4E342E"
                android:textSize="18sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="2dp"
                android:layout_margin="5dp"
                app:strokeColor="#F0D8C2"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <TextView
                        android:id="@+id/tvDailyQuote"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="人只要一想到生活的美好，就会有继续生活下去的勇气。"
                        android:textColor="#4E342E"
                        android:textSize="16sp"
                        android:lineSpacingExtra="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:layout_marginTop="10dp"
                        android:text="—— 今日阅读摘录"
                        android:textColor="#4E342E"
                        android:textSize="13sp" />
                </LinearLayout>


            </com.google.android.material.card.MaterialCardView>

            <!-- ========== Banner轮播 ViewPager2 + 圆点指示器 ========== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginVertical="8dp"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="本周推荐榜"
                    android:textColor="#4E342E"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/vpBanner"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"/>

                <!-- 底部小圆点 -->
<!--                app:tabIndicatorHeight="2dp"-->
<!--                app:tabIndicatorColor="#FF6D00"-->
<!--                app:tabPaddingStart="6dp"-->
<!--                app:tabPaddingEnd="6dp"-->
                <com.google.android.material.tabs.TabLayout
                    android:id="@+id/tabDot"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="6dp"
               />
            </LinearLayout>



            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="新书上架"
                android:textColor="#4E342E"
                android:textSize="18sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvNewBooks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:clipToPadding="false"
                android:paddingHorizontal="2dp" />



        </LinearLayout>
    </ScrollView>

</LinearLayout>
