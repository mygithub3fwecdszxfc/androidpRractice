<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 中间 -->
    <View
        android:id="@+id/box"
        android:layout_width="100dp"
        android:layout_height="50dp"
        android:layout_centerInParent="true"
        android:background="#F44336" />


    <!-- 和 box 顶部对齐，放在 box 左边 -->
    <View
        android:layout_width="100dp"
        android:layout_height="50dp"
        android:layout_toStartOf="@id/box"
        android:layout_marginEnd="30dp"
        android:layout_alignTop="@id/box"
        android:background="#84FFFF" />

    <!-- 和 box 底部对齐，放在 box 右边 -->
    <View
        android:layout_width="100dp"
        android:layout_height="50dp"
        android:layout_toEndOf="@id/box"
        android:layout_alignBottom="@id/box"
        android:layout_marginStart="30dp"
        android:background="#C51162" />

    <View
        android:layout_width="100dp"
        android:layout_height="50dp"
        android:layout_above="@id/box"
        android:layout_alignLeft="@id/box"
        android:layout_marginBottom="30dp"
        android:background="#C85700" />


    <View
        android:layout_width="100dp"
        android:layout_height="50dp"
        android:layout_below="@id/box"
        android:layout_alignLeft="@id/box"
        android:layout_marginTop="30dp"
        android:background="#11C56B" />

    <View
        android:layout_width="100dp"
        android:layout_height="50dp"
        android:layout_above="@id/box"
        android:layout_toLeftOf="@id/box"
        android:layout_marginTop="30dp"
        android:background="#11C56B" />




    <!-- 蓝色方块上方红色方块 -->
    <View
        android:layout_above="@id/box"
        android:layout_centerHorizontal="true"
        android:layout_width="100dp"
        android:layout_height="50dp"
        android:layout_marginBottom="100dp"
        android:background="#F44336" />





    <!-- 左上角 -->
    <View
        android:layout_width="100dp"
        android:layout_height="50dp"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:background="#FFEB3B" />

    <!-- 右上角 -->
    <View
        android:layout_width="100dp"
        android:layout_height="50dp"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true"
        android:background="#2196F3" />

    <!-- 左下角 -->
    <View
        android:layout_width="100dp"
        android:layout_height="50dp"
        android:layout_alignParentStart="true"
        android:layout_alignParentBottom="true"
        android:background="#8BC34A" />

    <!-- 右下角 -->
    <View
        android:layout_width="100dp"
        android:layout_height="50dp"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:background="#9C27B0" />

</RelativeLayout>